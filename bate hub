-- ⚙️ BIẾN
local farming = false
local player = game.Players.LocalPlayer

-- 🔍 HÀM TÌM ENEMY GẦN NHẤT
function getNearestEnemy()
    local nearest = nil
    local distance = math.huge

    for _, enemy in pairs(workspace.Enemies:GetChildren()) do
        if enemy:FindFirstChild("HumanoidRootPart") and enemy:FindFirstChild("Humanoid") then
            if enemy.Humanoid.Health > 0 then
                local dist = (player.Character.HumanoidRootPart.Position - enemy.HumanoidRootPart.Position).Magnitude
                if dist < distance then
                    distance = dist
                    nearest = enemy
                end
            end
        end
    end

    return nearest
end

-- 🥊 AUTO FARM
function autoFarm()
    while farming do
        task.wait(0.5)

        local char = player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then continue end

        local enemy = getNearestEnemy()
        if enemy then
            -- 📍 TELEPORT TỚI ENEMY
            char.HumanoidRootPart.CFrame = enemy.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)

            -- 🥊 ĐÁNH
            game:GetService("VirtualUser"):ClickButton1(Vector2.new())

        else
            print("Không tìm thấy enemy")
        end
    end
end

-- 🔘 BẬT/TẮT
Toggle.MouseButton1Click:Connect(function()
    farming = not farming
    Toggle.Text = farming and "AUTO FARM: ON" or "AUTO FARM: OFF"

    if farming then
        autoFarm()
    end
end)
